                <mxCell id="start" value="&lt;b&gt;Usuario en PhotoDetailView&lt;br&gt;revisando foto en canvas&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
