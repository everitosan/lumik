                </mxCell>
                <mxCell id="trigger" value="&lt;b&gt;Trigger de rotación&lt;/b&gt;&lt;br&gt;• Botones ↺ / ↻ en barra de herramientas del visor&lt;br&gt;• Keybindings: &lt;b&gt;rotateLeft / rotateRight&lt;/b&gt; (configurables en Settings)&lt;br&gt;• rotateLeft() / rotateRight() expuestos via &lt;b&gt;useImperativeHandle&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="450" y="200" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="canvas_note" value="&lt;b&gt;Modelo de rotación en canvas:&lt;/b&gt;&lt;br&gt;• RAW: preview en .previews/ con Orientation=1 (exiftool lo strip)&lt;br&gt;• JPEG: sin caché permanente — temp file en /tmp/, se descarta&lt;br&gt;• Canvas aplica ctx.rotate(rad) manualmente usando photo.rotation de BD&lt;br&gt;• Browser/WebView nunca auto-rota (Orientation=1 en ambos casos)&lt;br&gt;• Sin flash entre fotos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;align=left;spacingLeft=8;spacingTop=6;" parent="1" vertex="1">
                    <mxGeometry x="40" y="182.5" width="330" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="calc_new_rotation" value="Calcular nueva rotación absoluta:&lt;br&gt;rotateRight → &lt;b&gt;newRot = (localRotation + 90) % 360&lt;/b&gt;&lt;br&gt;rotateLeft → &lt;b&gt;newRot = (localRotation + 270) % 360&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="495" y="310" width="330" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="optimistic" value="&lt;b&gt;Actualización optimista:&lt;/b&gt; Canvas re-renderiza con ctx.rotate() — &lt;b&gt;sin re-render React&lt;/b&gt; (zoom/pan son refs)&lt;br&gt;requestAnimationFrame() garantiza que el canvas dibuja &lt;b&gt;antes&lt;/b&gt; de que empiece el invoke()&lt;br&gt;setSaveState(&#39;saving&#39;) → indicador amarillo &lt;i&gt;&#39;↻ Guardando…&#39;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="390" y="400" width="540" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="invoke" value="&lt;b&gt;api.savePhotoRotation()&lt;/b&gt; → invoke(&lt;b&gt;&#39;save_photo_rotation&#39;&lt;/b&gt;, { photoId, projectId, rotation: newRot })" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="360" y="553.5" width="600" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="be_validate" value="Rust: &lt;b&gt;save_photo_rotation()&lt;/b&gt; — validar rotation ∈ {0, 90, 180, 270}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="432.5" y="700" width="455" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="val_q" value="¿Válido?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="569" y="780" width="180" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="val_err" value="Error: &#39;Rotación inválida&#39;&lt;br&gt;→ retornar al frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="984" y="790" width="200" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="get_photo" value="project_db.get_photo(&amp;photo_id) — leer &lt;b&gt;old_rotation&lt;/b&gt; desde BD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="467.5" y="900" width="385" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="calc_delta" value="&lt;b&gt;delta = (rotation − old_rotation + 360) % 360&lt;/b&gt; — grados que debe girar la miniatura" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="416.5" y="970" width="485" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="db_update" value="&lt;b&gt;UPDATE photo SET rotation = ?&lt;/b&gt; WHERE id = ?&lt;br&gt;db/queries.rs: update_photo_rotation() — transacción síncrona&lt;br&gt;WAL mode activo (PRAGMA journal_mode=WAL) → &lt;b&gt;~50ms&lt;/b&gt; en SD card (antes ~1200ms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="407.5" y="1040" width="505" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="regen_thumb" value="&lt;b&gt;regenerate_rotated_thumbnail()&lt;/b&gt; [solo si delta ≠ 0]&lt;br&gt;• Leer &lt;i&gt;.thumbs/{photo_id}.jpg&lt;/i&gt; existente&lt;br&gt;• image crate: rotate90 / rotate180 / rotate270 según delta&lt;br&gt;• Sobreescribir el mismo archivo — &lt;b&gt;sin exiftool, solo píxeles&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="472.5" y="1129" width="375" height="80" as="geometry"/>
