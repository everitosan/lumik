        <mxCell id="ref_commands" value="&lt;b&gt;commands.rs&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;src-tauri/src/commands.rs&lt;/font&gt;&lt;br&gt;save_photo_rotation() ~L606&lt;br&gt;regenerate_rotated_thumbnail() ~L572&lt;br&gt;read_exif_rotation() ~L487" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1340" y="550" width="230" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="ref_db" value="&lt;b&gt;db/queries.rs&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;src-tauri/src/db/queries.rs&lt;/font&gt;&lt;br&gt;update_photo_rotation()&lt;br&gt;UPDATE photo SET rotation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1340" y="849" width="230" height="75" as="geometry"/>
        </mxCell>

        <mxCell id="ref_xmp" value="&lt;b&gt;xmp.rs&lt;/b&gt; (Android)&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;src-tauri/src/import/xmp.rs&lt;/font&gt;&lt;br&gt;update_xmp_orientation()&lt;br&gt;Sidecar {dng}.xmp — Rust puro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1340" y="1060" width="230" height="80" as="geometry"/>
        </mxCell>

