                <mxCell id="plat_q" value="Plataforma" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="560" y="1290" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="desktop_write" value="&lt;b&gt;Linux / Windows&lt;/b&gt;&lt;br&gt;&lt;i&gt;exiftool -IFD0:Orientation={val} -n -overwrite_original {dng}&lt;/i&gt;&lt;br&gt;Mapa EXIF: 90°→6 · 180°→3 · 270°→8 · 0°→1&lt;br&gt;Escribe en el &lt;b&gt;DNG original&lt;/b&gt; en disco externo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
