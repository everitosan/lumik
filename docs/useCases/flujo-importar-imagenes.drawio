                    <mxGeometry x="650" y="490" width="860" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="emit_result" value="Retornar &lt;b&gt;ImportResult&lt;/b&gt; al frontend: { total_files, successful, failed, failed_files[], videos_copied }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="560" y="594" width="1040" height="55" as="geometry"/>
