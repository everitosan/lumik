                </mxCell>
                <mxCell id="cleanup_ws" value="&lt;b&gt;workspace.cleanup()&lt;/b&gt; — eliminar directorio temp completo (fs::remove_dir_all)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="840" y="-646.5" width="480" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="prog_note" value="&lt;span&gt;Eventos Tauri emitidos al frontend:&lt;/span&gt;&lt;br&gt;app.emit(&#39;import-progress&#39;, progress)&lt;br&gt;──────────────────────────&lt;br&gt;0/3 → Copiando archivos&lt;br&gt;1/3 → Agregando metadatos&lt;br&gt;2/3 → Registrando en BD&lt;br&gt;3/3 → Completo&lt;br&gt;──────────────────────────&lt;br&gt;Granularidad por &lt;span&gt;fase&lt;/span&gt;, no por archivo&lt;br&gt;Frontend filtra por &lt;i&gt;session_id&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;align=left;spacingLeft=8;spacingTop=6;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="1730" y="-782" width="280" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="plat_q3" value="Plataforma" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="970" y="-532" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="exif_desktop" value="&lt;b&gt;exiftool -csv&lt;/b&gt; batch sobre todos los archivos&lt;br&gt;Extrae: Width, Height, DateTimeOriginal,&lt;br&gt;Make, Model, ISO, FNumber, ExposureTime,&lt;br&gt;FocalLength, LensModel, &lt;b&gt;IFD0:Orientation&lt;/b&gt; → rotation°&lt;br&gt;→ HashMap&lt;path, FileMetadata&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="-447" width="400" height="115" as="geometry"/>
