                    <mxGeometry x="195" y="-520" width="200" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="exif_android" value="&lt;b&gt;exif_android::extract_exif_metadata_batch()&lt;/b&gt;&lt;br&gt;Usa crate &lt;b&gt;rawler&lt;/b&gt; (sin exiftool)&lt;br&gt;Extrae mismos campos + &lt;b&gt;exif.orientation&lt;/b&gt; → rotation°&lt;br&gt;vía decodificación RAW nativa → HashMap&lt;path, meta&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
