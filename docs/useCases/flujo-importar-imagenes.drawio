                    <mxGeometry x="195" y="381" width="200" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="android_thumb" value="&lt;b&gt;exif_android::cache_thumbnail()&lt;/b&gt;&lt;br&gt;rawler::extract_thumbnail_pixels()&lt;br&gt;→ resize 320×320 · rotación EXIF aplicada&lt;br&gt;→ encode &lt;b&gt;JPEG&lt;/b&gt; → &lt;i&gt;.thumbs/{id}.jpg&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
