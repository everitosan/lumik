                </mxCell>
                <mxCell id="merge_exif" value="HashMap&lt;PathBuf, FileMetadata&gt; (incl. rotation) disponible para todos los archivos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="880" y="-299" width="400" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="build_dtos" value="Construir &lt;b&gt;CreatePhoto DTOs&lt;/b&gt;: dng_path · original_format · capture_date · dimensiones · ISO · apertura · velocidad · longitud focal · lente · &lt;b&gt;rotation&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="720" y="-222" width="720" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="db_insert" value="&lt;b&gt;project_db.create_photos_batch()&lt;/b&gt; — transacción SQLite única&lt;br&gt;• Genera UUID por foto&lt;br&gt;• INSERT INTO photo (id, project_id, dng_path, device_uuid, original_camera, original_format,&lt;br&gt;  capture_date, width, height, file_size_bytes, iso, aperture, shutter_speed, focal_length, lens_model, &lt;b&gt;rotation&lt;/b&gt;)&lt;br&gt;• Commit en éxito · Rollback en error (sin inserciones parciales)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="380" y="147" width="1400" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="plat_q4" value="Plataforma" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="970" y="302" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="desktop_thumb" value="&lt;b&gt;cache_thumbnail()&lt;/b&gt;&lt;br&gt;exiftool -b -PreviewImage (fallback -ThumbnailImage)&lt;br&gt;→ image crate: resize 320×320 · rotación EXIF aplicada&lt;br&gt;→ encode &lt;b&gt;JPEG&lt;/b&gt; → &lt;i&gt;.thumbs/{id}.jpg&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="396" width="400" height="110" as="geometry"/>
