                </mxCell>
                <mxCell id="wizard_s1" value="&lt;b&gt;Paso 1 — Seleccionar archivos&lt;/b&gt;&lt;br&gt;• Clic en &#39;Browse&#39; o arrastrar archivos (DropZone)&lt;br&gt;• Validar extensiones: RAW, DNG, JPEG, video (MP4, MOV…)&lt;br&gt;• Mostrar FileList con tamaño total acumulado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="882.5" y="-2520" width="405" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="note_android_uri" value="&lt;b&gt;Android:&lt;/b&gt; DocumentsUI devuelve&lt;br&gt;&lt;i&gt;content://...&lt;/i&gt; URIs&lt;br&gt;→ &lt;b&gt;resolveContentUri()&lt;/b&gt;&lt;br&gt;→ /storage/{UUID}/DCIM/..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1505" y="-2512.5" width="255" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="wizard_s2" value="&lt;b&gt;Paso 2 — Seleccionar destino&lt;/b&gt; (solo modo desktop completo)&lt;br&gt;• Elegir dispositivo de destino (useConnectedDevices)&lt;br&gt;• Elegir proyecto existente o crear uno nuevo&lt;br&gt;• Validar espacio libre ≥ tamaño total de archivos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="897.5" y="-2380" width="375" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="note_embedded" value="Omitido en modo &lt;b&gt;embedded&lt;/b&gt;&lt;br&gt;(desde ProjectDetail,&lt;br&gt;proyecto ya conocido)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1505" y="-2365" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="wizard_s3b" value="&lt;b&gt;Paso 3 — Confirmar e iniciar&lt;/b&gt;&lt;br&gt;• Resumen: N fotos + M videos | dispositivo | proyecto&lt;br&gt;• Usuario confirma → genera &lt;i&gt;session_id&lt;/i&gt; único" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="927.5" y="-2230" width="315" height="80" as="geometry"/>
                </mxCell>
