                <mxCell id="exiftool_meta" value="&lt;b&gt;rename_and_embed_metadata()&lt;/b&gt;&lt;br&gt;&lt;i&gt;exiftool&lt;/i&gt; batch sobre &lt;i&gt;workspace/files/&lt;/i&gt;:&lt;br&gt;• Rename: &lt;i&gt;{DateTimeOrig}__{proyecto}__%03c.{ext}&lt;/i&gt;&lt;br&gt;• Embed: Artist, Copyright, ImageDescription@Año,&lt;br&gt;  CreatorURL, CreatorEmail, UsageTerms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
