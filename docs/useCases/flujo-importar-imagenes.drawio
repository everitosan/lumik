                <mxCell id="move_media" value="&lt;b&gt;pipeline_move_to_dest()&lt;/b&gt; — mover a &lt;i&gt;{project}/_media/&lt;/i&gt; (+ sidecar .xmp si existe)&lt;br&gt;Implementado como Copy + Delete (seguro cross-filesystem)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#f57c00;fontSize=12;" parent="1" vertex="1">
