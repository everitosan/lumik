---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Lumik — Cull and organize your photo sessions without friction. Rate, tag and review your photos with a fast, keyboard-driven interface." />
    <title>Lumik — Cull and organize your photos, without friction</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      @import "@lumik/ui/tokens.css";
      @import "../styles/base.css";

      /* ── NAV ── */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
        height: 60px;
        background: var(--lumik-background);
        border-bottom: 1px solid var(--lumik-outline-variant);
        backdrop-filter: blur(12px);
      }

      .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .nav-brand img {
        width: 28px;
        height: 28px;
      }

      .nav-brand span {
        font-size: 18px;
        font-weight: 600;
        color: var(--lumik-primary);
        letter-spacing: -0.3px;
      }

      .nav-links {
        display: flex;
        gap: 32px;
        list-style: none;
      }

      .nav-links a {
        font-size: 14px;
        color: var(--lumik-on-surface-variant);
        transition: color var(--lumik-transition-fast);
      }

      .nav-links a:hover {
        color: var(--lumik-on-surface);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        border-radius: var(--lumik-radius-md);
        font-size: 14px;
        font-weight: 500;
        font-family: var(--lumik-font-primary);
        cursor: pointer;
        transition: opacity var(--lumik-transition-fast), background var(--lumik-transition-fast);
        border: none;
        text-decoration: none;
      }

      .btn-primary {
        background: var(--lumik-primary-container);
        color: #fff;
      }

      .btn-primary:hover {
        opacity: 0.88;
      }

      .btn-ghost {
        background: transparent;
        color: var(--lumik-on-surface-variant);
        border: 1px solid var(--lumik-outline-variant);
      }

      .btn-ghost:hover {
        background: var(--lumik-surface-container-low);
        color: var(--lumik-on-surface);
      }

      /* ── SECTIONS ── */
      section {
        padding: 96px 48px;
        max-width: 1200px;
        margin: 0 auto;
      }

      .section-label {
        font-size: 12px;
        font-family: var(--lumik-font-mono);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--lumik-primary);
        margin-bottom: 16px;
      }

      .section-title {
        font-size: 36px;
        font-weight: 700;
        color: var(--lumik-on-surface);
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin-bottom: 16px;
      }

      .section-sub {
        font-size: 18px;
        color: var(--lumik-on-surface-variant);
        max-width: 560px;
      }

      /* ── HERO ── */
      .hero {
        padding-top: 120px;
        padding-bottom: 80px;
        text-align: center;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        background: var(--lumik-surface-container-low);
        border: 1px solid var(--lumik-outline-variant);
        border-radius: var(--lumik-radius-full);
        font-size: 12px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-secondary);
        margin-bottom: 32px;
      }

      .hero h1 {
        font-size: clamp(36px, 5vw, 64px);
        font-weight: 700;
        color: var(--lumik-on-surface);
        letter-spacing: -1.5px;
        line-height: 1.1;
        max-width: 780px;
        margin: 0 auto 20px;
      }

      .hero p {
        font-size: 20px;
        color: var(--lumik-on-surface-variant);
        max-width: 560px;
        margin: 0 auto 40px;
        line-height: 1.6;
      }

      .hero-ctas {
        display: flex;
        gap: 12px;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 64px;
      }

      .hero-ctas .btn {
        padding: 12px 28px;
        font-size: 15px;
      }

      .hero-screenshot {
        position: relative;
        border-radius: var(--lumik-radius-xl);
        overflow: hidden;
        border: 1px solid var(--lumik-outline-variant);
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(176, 198, 255, 0.06);
        background: var(--lumik-surface-container-low);
      }

      .hero-screenshot img {
        width: 100%;
        height: auto;
        display: block;
      }

      /* ── WORKFLOW ── */
      .workflow {
        text-align: center;
        border-top: 1px solid var(--lumik-outline-variant);
      }

      .workflow-steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        margin-top: 56px;
        position: relative;
      }

      .workflow-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 24px;
        position: relative;
      }

      .workflow-step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 28px;
        right: -1px;
        width: calc(50% + 1px);
        height: 1px;
        background: linear-gradient(to right, var(--lumik-outline-variant), transparent);
      }

      .workflow-step:not(:first-child)::before {
        content: '';
        position: absolute;
        top: 28px;
        left: -1px;
        width: calc(50% + 1px);
        height: 1px;
        background: linear-gradient(to right, transparent, var(--lumik-outline-variant));
      }

      .workflow-icon {
        width: 56px;
        height: 56px;
        border-radius: var(--lumik-radius-lg);
        background: var(--lumik-surface-container-low);
        border: 1px solid var(--lumik-outline-variant);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 22px;
        position: relative;
        z-index: 1;
      }

      .workflow-step-num {
        font-size: 11px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-primary);
        font-weight: 500;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .workflow-step h3 {
        font-size: 16px;
        font-weight: 600;
        color: var(--lumik-on-surface);
        margin-bottom: 8px;
      }

      .workflow-step p {
        font-size: 14px;
        color: var(--lumik-on-surface-variant);
        line-height: 1.5;
      }

      /* ── FEATURES ── */
      .features {
        border-top: 1px solid var(--lumik-outline-variant);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 56px;
      }

      .feature-card {
        background: var(--lumik-surface-container-low);
        border: 1px solid var(--lumik-outline-variant);
        border-radius: var(--lumik-radius-lg);
        padding: 28px;
        transition: border-color var(--lumik-transition-normal);
      }

      .feature-card:hover {
        border-color: var(--lumik-primary);
      }

      .feature-icon {
        font-size: 26px;
        margin-bottom: 16px;
      }

      .feature-card h3 {
        font-size: 17px;
        font-weight: 600;
        color: var(--lumik-on-surface);
        margin-bottom: 10px;
      }

      .feature-card p {
        font-size: 14px;
        color: var(--lumik-on-surface-variant);
        line-height: 1.6;
      }

      .features-note {
        margin-top: 24px;
        font-size: 13px;
        font-style: italic;
        color: var(--lumik-outline);
        font-family: var(--lumik-font-mono);
      }

      /* ── SCREENSHOTS ── */
      .screenshots {
        border-top: 1px solid var(--lumik-outline-variant);
      }

      .screenshots-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 56px;
      }

      .screenshot-frame {
        border-radius: var(--lumik-radius-lg);
        overflow: hidden;
        border: 1px solid var(--lumik-outline-variant);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      }

      .screenshot-frame img {
        width: 100%;
        height: auto;
        display: block;
      }

      .screenshot-caption {
        margin-top: 10px;
        font-size: 13px;
        color: var(--lumik-outline);
        font-family: var(--lumik-font-mono);
        text-align: center;
      }

      .screenshots-grid--3 {
        grid-template-columns: repeat(3, 1fr);
      }

      /* ── PLATFORMS ── */
      .platforms {
        border-top: 1px solid var(--lumik-outline-variant);
        text-align: center;
      }

      .platforms-grid {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 56px;
      }

      .platform-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }

      .platform-icon {
        width: 64px;
        height: 64px;
        border-radius: var(--lumik-radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        border: 1px solid;
      }

      .platform-icon.available {
        background: rgba(85, 141, 255, 0.1);
        border-color: var(--lumik-primary-container);
        box-shadow: 0 0 24px rgba(85, 141, 255, 0.2);
      }

      .platform-icon.soon {
        background: var(--lumik-surface-container-low);
        border-color: var(--lumik-outline-variant);
        opacity: 0.5;
      }

      .platform-name {
        font-size: 15px;
        font-weight: 500;
        color: var(--lumik-on-surface);
      }

      .platform-badge {
        font-size: 11px;
        font-family: var(--lumik-font-mono);
        padding: 3px 10px;
        border-radius: var(--lumik-radius-full);
      }

      .platform-badge.available {
        background: rgba(85, 141, 255, 0.15);
        color: var(--lumik-primary);
      }

      .platform-badge.soon {
        background: var(--lumik-surface-container-high);
        color: var(--lumik-outline);
      }

      /* ── ROADMAP ── */
      .roadmap {
        border-top: 1px solid var(--lumik-outline-variant);
      }

      .roadmap-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 56px;
      }

      .roadmap-card {
        background: var(--lumik-surface-container-low);
        border: 1px solid var(--lumik-outline-variant);
        border-radius: var(--lumik-radius-lg);
        padding: 28px;
      }

      .roadmap-card h3 {
        font-size: 15px;
        font-weight: 600;
        font-family: var(--lumik-font-mono);
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--lumik-outline-variant);
      }

      .roadmap-card.now h3 {
        color: #4ade80;
      }

      .roadmap-card.soon h3 {
        color: var(--lumik-secondary);
      }

      .roadmap-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .roadmap-list li {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: var(--lumik-on-surface-variant);
      }

      .roadmap-list li .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .roadmap-card.now .dot {
        background: #4ade80;
      }

      .roadmap-card.soon .dot {
        background: var(--lumik-secondary);
      }

      /* ── FOOTER ── */
      footer {
        background: var(--lumik-surface-container-lowest);
        border-top: 1px solid var(--lumik-outline-variant);
        padding: 32px 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .footer-brand img {
        width: 22px;
        height: 22px;
      }

      .footer-brand span {
        font-size: 15px;
        font-weight: 600;
        color: var(--lumik-primary);
      }

      .footer-copy {
        font-size: 13px;
        color: var(--lumik-outline);
      }

      .footer-links {
        display: flex;
        gap: 24px;
      }

      .footer-links a {
        font-size: 13px;
        color: var(--lumik-outline);
        transition: color var(--lumik-transition-fast);
      }

      .footer-links a:hover {
        color: var(--lumik-on-surface-variant);
      }

      /* ── LIGHTBOX ── */
      .screenshot-frame {
        cursor: zoom-in;
      }

      .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 999;
        background: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
      }

      .lightbox.open {
        display: flex;
      }

      .lightbox-inner {
        position: relative;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .lightbox-img {
        max-width: 80vw;
        max-height: 88vh;
        border-radius: var(--lumik-radius-lg);
        border: 1px solid var(--lumik-outline-variant);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.7);
        object-fit: contain;
        display: block;
      }

      .lightbox-btn {
        background: var(--lumik-surface-container-high);
        border: 1px solid var(--lumik-outline-variant);
        color: var(--lumik-on-surface);
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 18px;
        flex-shrink: 0;
        transition: background var(--lumik-transition-fast), border-color var(--lumik-transition-fast);
      }

      .lightbox-btn:hover {
        background: var(--lumik-surface-bright);
        border-color: var(--lumik-primary);
      }

      .lightbox-close {
        position: absolute;
        top: -52px;
        right: 0;
        font-size: 16px;
      }

      .lightbox-caption {
        position: absolute;
        bottom: -36px;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 13px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-outline);
      }

      .lightbox-counter {
        position: absolute;
        top: -52px;
        left: 0;
        font-size: 12px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-outline);
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 900px) {
        .nav { padding: 0 24px; }
        .nav-links { display: none; }
        section { padding: 64px 24px; }
        .workflow-steps { grid-template-columns: 1fr 1fr; gap: 32px; }
        .workflow-step::before, .workflow-step::after { display: none; }
        .features-grid { grid-template-columns: 1fr; }
        .screenshots-grid, .screenshots-grid--3 { grid-template-columns: 1fr; }
        .roadmap-grid { grid-template-columns: 1fr; }
        footer { flex-direction: column; text-align: center; padding: 24px; }
      }

      @media (max-width: 600px) {
        .workflow-steps { grid-template-columns: 1fr; }
        .platforms-grid { flex-direction: column; align-items: center; }
      }
    </style>
  </head>
  <body>

    <!-- NAV -->
    <nav class="nav">
      <a class="nav-brand" href="/">
        <img src="/icon.png" alt="Lumik icon" />
        <span>Lumik</span>
      </a>
      <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#workflow">Workflow</a></li>
        <li><a href="#roadmap">Roadmap</a></li>
      </ul>
      <a class="btn btn-primary" href="/downloads">Download</a>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-badge">
        <span>🐧</span>
        <span>Available now for Linux</span>
      </div>
      <h1>Cull and organize your photos, without friction.</h1>
      <p>Browse your sessions, rate your shots and remove the rejects — fast, keyboard-driven, no subscription required.</p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href="/downloads">
          ↓ Download for Linux
        </a>
        <a class="btn btn-ghost" href="https://github.com/everitosan/lumik" target="_blank" rel="noopener">
          View on GitHub ↗
        </a>
      </div>
      <div class="hero-screenshot">
        <img src="/screenshot-dashboard.png" alt="Lumik dashboard — photo sessions organized by project and year" />
      </div>
    </section>

    <!-- WORKFLOW -->
    <section class="workflow" id="workflow">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Simple by design</h2>
      <p class="section-sub">Open your session, review every shot, keep the best. That's it.</p>

      <div class="workflow-steps">
        <div class="workflow-step">
          <div class="workflow-icon">📂</div>
          <div class="workflow-step-num">01</div>
          <h3>Open your session</h3>
          <p>Browse your projects organized by date. Find any session in seconds</p>
        </div>
        <div class="workflow-step">
          <div class="workflow-icon">🖼️</div>
          <div class="workflow-step-num">02</div>
          <h3>Review each photo</h3>
          <p>Full-screen canvas viewer with zoom, pan, rotate and live histogram</p>
        </div>
        <div class="workflow-step">
          <div class="workflow-icon">⭐</div>
          <div class="workflow-step-num">03</div>
          <h3>Rate & tag</h3>
          <p>Stars, color labels, custom tags — all from the keyboard without lifting your hands</p>
        </div>
        <div class="workflow-step">
          <div class="workflow-icon">✅</div>
          <div class="workflow-step-num">04</div>
          <h3>Cull your picks</h3>
          <p>Mark your best shots with a single keypress — culled photos are your selection</p>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" id="features">
      <p class="section-label">Features</p>
      <h2 class="section-title">Built for culling</h2>
      <p class="section-sub">Every tool focused on one thing: getting through your shots fast and keeping only the best.</p>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🖥️</div>
          <h3>Professional canvas viewer</h3>
          <p>Canvas-based rendering with smooth zoom, pan, and rotate. Live RGB histogram calculated off-thread. Zero flash between photos.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⌨️</div>
          <h3>Keyboard-first</h3>
          <p>Every action mapped to a shortcut, fully configurable. Rate, cull, navigate — all without touching the mouse.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📁</div>
          <h3>Projects & sessions</h3>
          <p>Your photos organized by project and date. Multiple external disks, each detected automatically — no manual paths.</p>
        </div>
      </div>
    </section>

    <!-- SCREENSHOTS -->
    <section class="screenshots">
      <p class="section-label">The app</p>
      <h2 class="section-title">See it in action</h2>

      <div class="screenshots-grid screenshots-grid--3">
        <div>
          <div class="screenshot-frame" data-lightbox="0">
            <img src="/screenshot-dashboard.png" alt="Lumik dashboard — all your projects organized by year" />
          </div>
          <p class="screenshot-caption">Dashboard — all sessions at a glance</p>
        </div>
        <div>
          <div class="screenshot-frame" data-lightbox="1">
            <img src="/screenshot-grid.png" alt="Lumik session grid — photos organized by date with ratings and color labels" />
          </div>
          <p class="screenshot-caption">Session grid — rated and tagged at a glance</p>
        </div>
        <div>
          <div class="screenshot-frame" data-lightbox="2">
            <img src="/screenshot-viewer.png" alt="Lumik photo viewer — canvas viewer with histogram, EXIF data, rating and culling controls" />
          </div>
          <p class="screenshot-caption">Viewer — histogram, EXIF, rating and culling</p>
        </div>
      </div>
    </section>

    <!-- PLATFORMS -->
    <section class="platforms">
      <p class="section-label">Availability</p>
      <h2 class="section-title">Cross-platform</h2>
      <p class="section-sub">Available today on Linux. Windows and macOS are on the roadmap.</p>

      <div class="platforms-grid">
        <div class="platform-item">
          <div class="platform-icon available">🐧</div>
          <span class="platform-name">Linux</span>
          <span class="platform-badge available">Available</span>
        </div>
        <div class="platform-item">
          <div class="platform-icon soon">🪟</div>
          <span class="platform-name">Windows</span>
          <span class="platform-badge soon">Coming soon</span>
        </div>
        <div class="platform-item">
          <div class="platform-icon soon">🍎</div>
          <span class="platform-name">macOS</span>
          <span class="platform-badge soon">Coming soon</span>
        </div>
      </div>
    </section>

    <!-- ROADMAP -->
    <section class="roadmap" id="roadmap">
      <p class="section-label">Roadmap</p>
      <h2 class="section-title">Where we are</h2>
      <p class="section-sub">Lumik is in active development. Here's what's working today and what's next.</p>

      <div class="roadmap-grid">
        <div class="roadmap-card now">
          <h3>✓ Available now</h3>
          <ul class="roadmap-list">
            <li><span class="dot"></span>Import RAW files to external disk</li>
            <li><span class="dot"></span>Rating, tagging and culling</li>
            <li><span class="dot"></span>Canvas viewer with live RGB histogram</li>
            <li><span class="dot"></span>Configurable keyboard shortcuts</li>
