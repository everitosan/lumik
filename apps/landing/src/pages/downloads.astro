---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Download Lumik — available for Linux, Windows and macOS." />
    <title>Download Lumik</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      @import "@lumik/ui/tokens.css";
      @import "../styles/base.css";

      /* ── NAV ── */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
        height: 60px;
        background: var(--lumik-background);
        border-bottom: 1px solid var(--lumik-outline-variant);
      }
      .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .nav-brand img { width: 28px; height: 28px; }
      .nav-brand span {
        font-size: 18px;
        font-weight: 600;
        color: var(--lumik-primary);
      }
      .nav-back {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: var(--lumik-on-surface-variant);
        text-decoration: none;
        transition: color 150ms ease;
      }
      .nav-back:hover { color: var(--lumik-on-surface); }

      /* ── PAGE ── */
      .page {
        max-width: 860px;
        margin: 0 auto;
        padding: 64px 48px 96px;
      }

      .page-header {
        margin-bottom: 48px;
      }
      .page-label {
        font-size: 12px;
        font-family: var(--lumik-font-mono);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--lumik-primary);
        margin-bottom: 12px;
      }
      .page-title {
        font-size: 40px;
        font-weight: 700;
        color: var(--lumik-on-surface);
        letter-spacing: -0.5px;
        margin-bottom: 12px;
      }
      .page-sub {
        font-size: 16px;
        color: var(--lumik-on-surface-variant);
      }

      /* ── OS TABS ── */
      .os-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 40px;
        border-bottom: 1px solid var(--lumik-outline-variant);
        padding-bottom: 0;
      }
      .os-tab {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 500;
        color: var(--lumik-on-surface-variant);
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        cursor: pointer;
        font-family: var(--lumik-font-primary);
        transition: color 150ms ease, border-color 150ms ease;
      }
      .os-tab:hover { color: var(--lumik-on-surface); }
      .os-tab.active {
        color: var(--lumik-primary);
        border-bottom-color: var(--lumik-primary-container);
      }
      .os-tab:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .os-tab .soon {
        font-size: 10px;
        font-family: var(--lumik-font-mono);
        background: var(--lumik-surface-container-high);
        color: var(--lumik-outline);
        padding: 2px 6px;
        border-radius: 4px;
      }

      /* ── STATES ── */
      .state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 64px 0;
        color: var(--lumik-on-surface-variant);
        font-size: 15px;
      }
      .state-icon { font-size: 32px; }
      .spinner {
        width: 28px;
        height: 28px;
        border: 2px solid var(--lumik-outline-variant);
        border-top-color: var(--lumik-primary-container);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* ── RELEASE LIST ── */
      #releases-list { display: flex; flex-direction: column; gap: 16px; }

      .release-card {
        background: var(--lumik-surface-container-low);
        border: 1px solid var(--lumik-outline-variant);
        border-radius: 12px;
        overflow: hidden;
      }

      .release-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px;
        gap: 16px;
        flex-wrap: wrap;
      }

      .release-meta { display: flex; align-items: center; gap: 12px; }

      .release-tag {
        font-size: 16px;
        font-weight: 600;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-on-surface);
      }
      .release-badge {
        font-size: 11px;
        font-family: var(--lumik-font-mono);
        padding: 3px 8px;
        border-radius: 4px;
        background: rgba(85, 141, 255, 0.15);
        color: var(--lumik-primary);
      }
      .release-date {
        font-size: 13px;
        color: var(--lumik-outline);
        font-family: var(--lumik-font-mono);
      }
      .release-notes-link {
        font-size: 13px;
        color: var(--lumik-primary);
        text-decoration: none;
        transition: opacity 150ms ease;
      }
      .release-notes-link:hover { opacity: 0.75; }

      .release-assets {
        border-top: 1px solid var(--lumik-outline-variant);
        display: flex;
        flex-direction: column;
      }

      .asset-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        gap: 16px;
        border-bottom: 1px solid var(--lumik-outline-variant);
        transition: background 150ms ease;
      }
      .asset-row:last-child { border-bottom: none; }
      .asset-row:hover { background: var(--lumik-surface-container); }

      .asset-info { display: flex; align-items: center; gap: 12px; }

      .asset-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--lumik-surface-container-high);
        border: 1px solid var(--lumik-outline-variant);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
      }

      .asset-name {
        font-size: 14px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-on-surface);
      }
      .asset-desc {
        font-size: 12px;
        color: var(--lumik-outline);
        margin-top: 2px;
      }
      .asset-size {
        font-size: 12px;
        font-family: var(--lumik-font-mono);
        color: var(--lumik-outline);
        flex-shrink: 0;
      }

      .btn-download {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        background: var(--lumik-primary-container);
        color: #fff;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        font-family: var(--lumik-font-primary);
        text-decoration: none;
        flex-shrink: 0;
        transition: opacity 150ms ease;
      }
      .btn-download:hover { opacity: 0.85; }

      .no-assets {
        padding: 24px;
        font-size: 14px;
        color: var(--lumik-outline);
        font-style: italic;
        text-align: center;
      }

      /* ── COMING SOON ── */
      .coming-soon {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 80px 0;
        text-align: center;
      }
      .coming-soon .icon { font-size: 40px; opacity: 0.4; }
      .coming-soon h3 {
        font-size: 18px;
        font-weight: 600;
        color: var(--lumik-on-surface);
      }
      .coming-soon p { font-size: 14px; color: var(--lumik-outline); }

      @media (max-width: 600px) {
        .nav { padding: 0 16px; }
        .page { padding: 40px 16px 64px; }
        .asset-row { flex-wrap: wrap; }
        .asset-size { display: none; }
      }
    </style>
  </head>
  <body>

    <nav class="nav">
      <a class="nav-brand" href="/">
        <img src="/icon.png" alt="Lumik" />
        <span>Lumik</span>
      </a>
      <a class="nav-back" href="/">← Back to home</a>
    </nav>

    <div class="page">
      <div class="page-header">
        <p class="page-label">Downloads</p>
        <h1 class="page-title">Get Lumik</h1>
        <p class="page-sub" id="os-hint">Detecting your operating system…</p>
      </div>

      <div class="os-tabs" role="tablist">
        <button class="os-tab" role="tab" data-os="linux" id="tab-linux">
          🐧 Linux
        </button>
        <button class="os-tab" role="tab" data-os="windows" disabled>
          🪟 Windows <span class="soon">soon</span>
        </button>
        <button class="os-tab" role="tab" data-os="macos" disabled>
          🍎 macOS <span class="soon">soon</span>
        </button>
      </div>

      <!-- Linux panel -->
      <div id="panel-linux">
        <div class="state" id="state-loading">
          <div class="spinner"></div>
          <span>Loading releases…</span>
        </div>
        <div class="state" id="state-error" style="display:none">
          <span class="state-icon">⚠️</span>
          <span>Could not load releases. <a href="https://github.com/everitosan/lumik/releases" target="_blank" rel="noopener" style="color:var(--lumik-primary)">View on GitHub ↗</a></span>
        </div>
        <div id="releases-list" style="display:none"></div>
      </div>

      <!-- Windows / macOS placeholders -->
      <div id="panel-windows" style="display:none">
        <div class="coming-soon">
          <div class="icon">🪟</div>
          <h3>Windows build coming soon</h3>
          <p>Follow the <a href="https://github.com/everitosan/lumik" target="_blank" rel="noopener" style="color:var(--lumik-primary)">GitHub repo</a> to be notified.</p>
        </div>
      </div>
      <div id="panel-macos" style="display:none">
        <div class="coming-soon">
          <div class="icon">🍎</div>
          <h3>macOS build coming soon</h3>
          <p>Follow the <a href="https://github.com/everitosan/lumik" target="_blank" rel="noopener" style="color:var(--lumik-primary)">GitHub repo</a> to be notified.</p>
        </div>
      </div>
    </div>

    <script>
      const REPO = 'everitosan/lumik';
      const API  = `https://api.github.com/repos/${REPO}/releases`;

      // ── OS detection ──────────────────────────────────────────
      function detectOS() {
        const ua = navigator.userAgent.toLowerCase();
        if (ua.includes('win'))   return 'windows';
        if (ua.includes('mac'))   return 'macos';
        return 'linux';
      }

      // ── Tab switching ─────────────────────────────────────────
      const panels = { linux: 'panel-linux', windows: 'panel-windows', macos: 'panel-macos' };
      let activeOS = 'linux';

      function activateTab(os) {
        activeOS = os;
        document.querySelectorAll('.os-tab').forEach(t => t.classList.remove('active'));
        const tab = document.querySelector(`[data-os="${os}"]`);
        if (tab) tab.classList.add('active');
        Object.entries(panels).forEach(([key, id]) => {
          const el = document.getElementById(id);
          if (el) el.style.display = key === os ? '' : 'none';
        });
      }

      document.querySelectorAll('.os-tab:not(:disabled)').forEach(tab => {
        tab.addEventListener('click', () => activateTab(tab.dataset.os));
      });

      // ── Asset helpers ─────────────────────────────────────────
      function assetIcon(name) {
        if (name.endsWith('.deb'))     return '📦';
        if (name.endsWith('.AppImage')) return '🗂️';
        if (name.endsWith('.rpm'))     return '📦';
        if (name.endsWith('.exe') || name.endsWith('.msi')) return '🪟';
        if (name.endsWith('.dmg') || name.endsWith('.app')) return '🍎';
        return '📄';
      }

      function assetDesc(name) {
        if (name.endsWith('.deb'))      return 'Debian / Ubuntu (.deb)';
        if (name.endsWith('.AppImage')) return 'Universal Linux (AppImage) — recommended if unsure';
        if (name.endsWith('.rpm'))      return 'Fedora / openSUSE (.rpm)';
        if (name.endsWith('.exe'))      return 'Windows installer';
        if (name.endsWith('.msi'))      return 'Windows MSI package';
        if (name.endsWith('.dmg'))      return 'macOS disk image';
        return name;
      }

      function formatSize(bytes) {
        if (!bytes) return '';
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(0)} KB`;
        return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
      }

      function isLinuxAsset(name) {
        return name.endsWith('.deb') || name.endsWith('.AppImage') || name.endsWith('.rpm');
      }

      function formatDate(iso) {
        return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      }

      // ── Render ────────────────────────────────────────────────
      function renderReleases(releases) {
        const list = document.getElementById('releases-list');
        const filtered = releases.filter(r => !r.draft);

        if (!filtered.length) {
          list.innerHTML = '<div class="state"><span class="state-icon">📭</span><span>No releases yet.</span></div>';
          list.style.display = '';
          return;
        }

        list.innerHTML = filtered.map((release, i) => {
          const assets = release.assets.filter(a => isLinuxAsset(a.name));
          const isLatest = i === 0;

          const assetsHtml = assets.length
            ? assets.map(asset => `
                <div class="asset-row">
                  <div class="asset-info">
                    <div class="asset-icon">${assetIcon(asset.name)}</div>
                    <div>
                      <div class="asset-name">${asset.name}</div>
                      <div class="asset-desc">${assetDesc(asset.name)}</div>
                    </div>
                  </div>
                  <span class="asset-size">${formatSize(asset.size)}</span>
                  <a class="btn-download" href="${asset.browser_download_url}" download>
                    ↓ Download
                  </a>
                </div>`).join('')
            : `<div class="no-assets">No Linux assets for this release.</div>`;

          return `
            <div class="release-card">
              <div class="release-header">
                <div class="release-meta">
                  <span class="release-tag">${release.tag_name}</span>
                  ${isLatest ? '<span class="release-badge">latest</span>' : ''}
                </div>
                <div style="display:flex;align-items:center;gap:16px">
                  <span class="release-date">${formatDate(release.published_at)}</span>
                  <a class="release-notes-link" href="${release.html_url}" target="_blank" rel="noopener">
                    Release notes ↗
                  </a>
                </div>
              </div>
              <div class="release-assets">${assetsHtml}</div>
            </div>`;
        }).join('');

        list.style.display = '';
      }

      // ── Fetch ─────────────────────────────────────────────────
      async function loadReleases() {
        try {
          const res = await fetch(API);
          if (!res.ok) throw new Error(`GitHub API ${res.status}`);
          const releases = await res.json();
          document.getElementById('state-loading').style.display = 'none';
          renderReleases(releases);
        } catch {
          document.getElementById('state-loading').style.display = 'none';
          document.getElementById('state-error').style.display = '';
        }
      }

      // ── Init ──────────────────────────────────────────────────
      const detectedOS = detectOS();
      const hint = document.getElementById('os-hint');

      // Only auto-select Linux since others are disabled
      activateTab('linux');

      if (detectedOS === 'linux') {
        hint.textContent = 'Linux detected — choose your package format below.';
      } else if (detectedOS === 'windows') {
        hint.textContent = 'Windows detected — Windows build is coming soon. Linux build available now.';
      } else {
        hint.textContent = 'macOS detected — macOS build is coming soon. Linux build available now.';
      }

      loadReleases();
    </script>

  </body>
</html>
