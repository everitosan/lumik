{
  "$schema": "https://schemas.tauri.app/config/2/capabilities",
  "identifier": "default",
  "description": "Default capabilities for Lumik",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/dnglab",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-stat"
  ]
}
